{
  "redirects": [
    {
      "source": "/blog",
      "destination": "https://blog.canweaffordthis.com",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "https://blog.canweaffordthis.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/roi",
      "destination": "/roi.html"
    }
  ]
}
